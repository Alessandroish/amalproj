# ── Пример переменных окружения ──
# На Railway эти значения задаются в разделе Variables (НЕ в коде).
# Локально можно скопировать этот файл в .env и подставить свои значения.

# Секрет для подписи сессий — длинная случайная строка.
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=замени-на-длинную-случайную-строку

# Данные для входа в админку (/admin/login)
ADMIN_USER=admin
ADMIN_PASSWORD=придумай-надёжный-пароль
ADMIN_PIN=придумай-пин

# Путь к файлу базы данных.
# На Railway укажи путь внутри постоянного тома (Volume), например /data/site.db,
# иначе база будет обнуляться при каждом редеплое.
DB_PATH=site.db
